{
    "workbench.iconTheme": "symbols",
    "symbols.hidesExplorerArrows": false,
    "editor.rulers": [
        80,
        120
    ],
    "workbench.startupEditor": "newUntitledFile",
    "editor.renderLineHighlight": "gutter",
    "workbench.editor.labelFormat": "short",
    "editor.semanticHighlighting.enabled": true,
    "breadcrumbs.enabled": false,
    "workbench.activityBar.location": "hidden",
    "editor.minimap.enabled": false,
    "window.commandCenter": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.compactFolders": false,
    "apc.electron": {
        "titleBarStyle": "hiddenInset",
        "frame": false
    },
    "apc.header": {
        "height": 36
    },
    "apc.stylesheet": {
        ".title-label > h2": "display: none",
        ".editor-actions": "display: none",
        ".titlebar-center": "display: none !important;"
    },
    "apc.listRow": {
        "height": 24
    },
    "symbols.files.associations": {
        "app.module.ts": "nest",
        "*.service.ts": "nest",
        "*.module.ts": "nest"
    },
    "explorer.fileNesting.enabled": true,
    "typescript.tsserver.log": "off",
    "javascript.suggest.autoImports": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.suggest.autoImports": true,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "editor.tabSize": 2,
    "tailwindCSS.emmetCompletions": true,
    "terminal.integrated.fontFamily": "MesloLGL Nerd Font Regular",
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "workbench.colorTheme": "Dracula.min",
    "workbench.tree.enableStickyScroll": false,
    "git.confirmSync": false,
    "editor.foldingStrategy": "indentation",
    "diffEditor.ignoreTrimWhitespace": false,
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[typescript]": {
        "editor.defaultFormatter": "denoland.vscode-deno"
    },
    "[javascript]": {
        "editor.defaultFormatter": "denoland.vscode-deno"
    },
    "[scss]": {
        "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "denoland.vscode-deno"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "denoland.vscode-deno"
    },
    "editor.stickyScroll.enabled": false,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "liveServer.settings.donotShowInfoMsg": true,
    "workbench.editor.empty.hint": "hidden",
    "scm.showHistoryGraph": false,
    "git.autofetch": true,
    "editor.wordWrap": "on",
    "deno.documentPreloadLimit": 0,
    "deno.internalDebug": false,
    "deno.enable": true,
    "deno.lint": true,
    "deno.unstable": true,
    "deno.suggest.imports.autoDiscover": false,
    "deno.disablePaths": [
        "./node_modules",
        "./deno.lock"
    ],
    "yaml.schemas": {
        "file:///Users/marcoferreira/.cursor/extensions/atlassian.atlascode-3.0.10/resources/schemas/pipelines-schema.json": "bitbucket-pipelines.yml"
    },
    "workbench.editorAssociations": {
        "*.svg": "default",
        "*.md": "default",
        "*.csv": "default"
    },
    "workbench.colorCustomizations": {},
    "vscode-pets.petSize": "medium",
    "vscode-pets.petColor": "black",
    "vscode-pets.throwBallWithMouse": true,
    "[prisma]": {
        "editor.defaultFormatter": "Prisma.prisma",
        "editor.formatOnSave": true
    },
    "editor.formatOnSave": false,
    "security.promptForLocalFileProtocolHandling": false,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "claudeCode.preferredLocation": "sidebar",
    "window.autoDetectColorScheme": false
}