# ~/.zsh/aliases.zsh
# Shell aliases and command replacements

# ============================================================================
# File Listing (lsd)
# ============================================================================
alias ls="lsd"
alias ll="lsd -la"
alias la="lsd -a"
alias lt="lsd --tree"
alias l="lsd -l"

# ============================================================================
# Modern Replacements
# ============================================================================
alias cat="bat"
alias find="fd"
alias du="dust"
alias top="btop"
alias y="yazi"

# ============================================================================
# Safety Nets
# ============================================================================
alias rm="rm -i"
alias cp="cp -i"
alias mv="mv -i"

# ============================================================================
# Convenience
# ============================================================================
alias reload="source ~/.zshrc"
alias zshconfig="$EDITOR ~/dotfiles/zsh/.zshrc"
alias dotfiles="cd ~/dotfiles"

# ============================================================================
# Clipboard
# ============================================================================
alias pbc="pbcopy"
alias pbp="pbpaste"

# ============================================================================
# Process Management
# ============================================================================
alias ports="lsof -iTCP -sTCP:LISTEN -n -P"

# ============================================================================
# Git (complementos ao OMZP::git — OMZ não define `gs` por conflito com ghostscript)
# ============================================================================
alias gs="git status"
